# Dependencies
node_modules/

# Build artifacts (generated by circom compiler)
build/*.r1cs
build/*.sym
build/password_policy_js/

# Trusted setup files (too large for git, 50-200MB)
setup/*.ptau
setup/*.zkey

# Generated proof outputs (overwritten each run)
proofs/proof.json
proofs/public.json
proofs/metrics.json

# Witness files
*.wtns
input.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json

# NOTE: setup/verification_key.json is NOT ignored — it must be committed
# so the verifier can be used without re-running setup.
